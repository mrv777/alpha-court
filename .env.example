XAI_API_KEY=                 # xAI API key (console.x.ai)
DATABASE_PATH=./data/court.db
NEXT_PUBLIC_APP_URL=         # For OG image URLs and share links
DEBUG_ENABLED=false          # Enable /debug page
JUPITER_API_KEY=             # Optional: Jupiter paid tier for higher rate limits
LOG_LEVEL=info               # debug | info | warn | error
LOG_PATH=                    # Optional: custom log directory (default: ./data/logs)

# Rate Limiting
COOLDOWN_HOURS=2             # Hours between trials for same token+chain (web UI)

# x402 Payment Protocol (agent-to-agent payments)
X402_ENABLED=false           # Enable x402 payment gating on API routes
X402_WALLET_ADDRESS=         # EVM wallet to receive USDC payments
X402_COST_CENTS=100          # Trial cost in cents ($1.00 per debate)
X402_FACILITATOR_URL=https://x402.org/facilitator  # Testnet facilitator (free)
X402_NETWORK=eip155:84532    # Base Sepolia testnet (use eip155:8453 for mainnet)
